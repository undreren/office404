{
  "name": "office404",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pages": "tsc -b && BASE_PATH=/office404/ vite build",
    "preview": "vite preview",
    "preview:pages": "BASE_PATH=/office404/ vite preview",
